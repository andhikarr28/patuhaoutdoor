generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model barang {
  id_barang     Int             @id @default(autoincrement())
  id_kategori   Int
  artikel       String?         @db.VarChar(50)
  kode_seri     String?         @db.VarChar(50)
  nama_barang   String          @db.VarChar(150)
  brand         String?         @db.VarChar(100)
  spesifikasi   String?
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  kategori      kategori        @relation(fields: [id_kategori], references: [id_kategori], onDelete: NoAction, onUpdate: NoAction, map: "fk_barang_kategori")
  varian_barang varian_barang[]
}

model detail_pembelian {
  id_detail_pembelian Int           @id @default(autoincrement())
  id_pembelian        Int
  id_varian           Int
  qty                 Int
  harga_satuan        Decimal       @db.Decimal(12, 2)
  diskon              Decimal?      @default(0) @db.Decimal(12, 2)
  subtotal            Decimal       @db.Decimal(12, 2)
  pembelian           pembelian     @relation(fields: [id_pembelian], references: [id_pembelian], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_pembelian")
  varian_barang       varian_barang @relation(fields: [id_varian], references: [id_varian], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_pembelian_varian")
}

model detail_penjualan {
  id_detail_penjualan Int           @id @default(autoincrement())
  id_penjualan        Int
  id_varian           Int
  qty                 Int
  harga               Decimal       @db.Decimal(12, 2)
  subtotal            Decimal       @db.Decimal(12, 2)
  penjualan           penjualan     @relation(fields: [id_penjualan], references: [id_penjualan], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_penjualan")
  varian_barang       varian_barang @relation(fields: [id_varian], references: [id_varian], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_penjualan_varian")
}

model kategori {
  id_kategori   Int      @id @default(autoincrement())
  nama_kategori String   @db.VarChar(100)
  barang        barang[]
}

model marketplace {
  id_marketplace      Int                   @id @default(autoincrement())
  nama_marketplace    String                @db.VarChar(50)
  status              Boolean?              @default(true)
  last_sync           DateTime?             @db.Timestamp(6)
  marketplace_product marketplace_product[]
}

model marketplace_product {
  id_mapping          Int           @id @default(autoincrement())
  id_varian           Int
  id_marketplace      Int
  external_product_id String?       @db.VarChar(100)
  external_sku        String?       @db.VarChar(100)
  created_at          DateTime?     @default(now()) @db.Timestamp(6)
  marketplace         marketplace   @relation(fields: [id_marketplace], references: [id_marketplace], onDelete: NoAction, onUpdate: NoAction, map: "fk_mapping_marketplace")
  varian_barang       varian_barang @relation(fields: [id_varian], references: [id_varian], onDelete: NoAction, onUpdate: NoAction, map: "fk_mapping_varian")
}

model pembelian {
  id_pembelian      Int                @id @default(autoincrement())
  no_faktur         String             @unique @db.VarChar(50)
  tanggal_pembelian DateTime           @db.Date
  id_supplier       Int
  total_brutto      Decimal?           @default(0) @db.Decimal(12, 2)
  total_diskon      Decimal?           @default(0) @db.Decimal(12, 2)
  total_netto       Decimal?           @default(0) @db.Decimal(12, 2)
  id_user           Int?
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  detail_pembelian  detail_pembelian[]
  supplier          supplier           @relation(fields: [id_supplier], references: [id_supplier], onDelete: NoAction, onUpdate: NoAction, map: "fk_pembelian_supplier")
  users             users?             @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction, map: "fk_pembelian_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model penjualan {
  id_penjualan      Int                @id @default(autoincrement())
  no_nota           String             @unique @db.VarChar(50)
  tanggal_penjualan DateTime           @db.Date
  channel           String             @db.VarChar(20)
  total             Decimal?           @default(0) @db.Decimal(12, 2)
  id_user           Int?
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  detail_penjualan  detail_penjualan[]
  users             users?             @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction, map: "fk_penjualan_user")
}

model stok_log {
  id_log         Int           @id @default(autoincrement())
  id_varian      Int
  tipe_transaksi String        @db.VarChar(20)
  qty            Int
  stok_sebelum   Int
  stok_sesudah   Int
  referensi      String?       @db.VarChar(100)
  created_at     DateTime?     @default(now()) @db.Timestamp(6)
  varian_barang  varian_barang @relation(fields: [id_varian], references: [id_varian], onDelete: NoAction, onUpdate: NoAction, map: "fk_stok_log_varian")
}

model supplier {
  id_supplier   Int         @id @default(autoincrement())
  nama_supplier String      @db.VarChar(150)
  alamat        String?
  no_hp         String?     @db.VarChar(20)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  pembelian     pembelian[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id_user      Int         @id @default(autoincrement())
  username     String      @unique @db.VarChar(50)
  password     String      @db.VarChar(255)
  nama_lengkap String      @db.VarChar(100)
  role         String      @db.VarChar(20)
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  pembelian    pembelian[]
  penjualan    penjualan[]
}

model varian_barang {
  id_varian           Int                   @id @default(autoincrement())
  id_barang           Int
  warna               String?               @db.VarChar(50)
  ukuran              String?               @db.VarChar(20)
  sku                 String?               @unique @db.VarChar(100)
  harga_jual          Decimal               @db.Decimal(12, 2)
  stok                Int?                  @default(0)
  stok_minimum        Int?                  @default(5)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  detail_pembelian    detail_pembelian[]
  detail_penjualan    detail_penjualan[]
  marketplace_product marketplace_product[]
  stok_log            stok_log[]
  barang              barang                @relation(fields: [id_barang], references: [id_barang], onDelete: NoAction, onUpdate: NoAction, map: "fk_varian_barang")
}
